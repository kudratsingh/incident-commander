# Anthropic
ANTHROPIC_API_KEY=

# Models (verify current strings against https://docs.claude.com before changing)
AGENT_MODEL=claude-sonnet-4-6
JUDGE_MODEL=

# Platform connection. MCP and REST are separate URLs; the platform runs MCP
# as its own process (platform ADR-0006). For local development against
# `make demo`, MCP is at http://localhost:8001/mcp. If 8001 is already in
# use on your host (e.g. you have a native platform running), override
# DEMO_MCP_HOST_PORT below and update PLATFORM_MCP_URL to match.
PLATFORM_MCP_URL=http://localhost:8001/mcp
PLATFORM_REST_URL=http://localhost:8000
# Host port `make demo` publishes for the platform MCP service. Only read
# by demo/compose.yml — the agent itself uses PLATFORM_MCP_URL.
DEMO_MCP_HOST_PORT=8001
# Service-account bearer token for MCP (platform naming convention: sa_*).
# Provisioned on the platform side under scope telemetry:read + incidents:read
# for the `incident-commander` seed principal.
PLATFORM_TOKEN=
PLATFORM_WEBHOOK_SECRET=

# Agent-owned Postgres
DATABASE_URL=

# Per-incident hard budgets
BUDGET_MAX_TOOL_CALLS=25
BUDGET_MAX_TOKENS=
BUDGET_MAX_SECONDS=
BUDGET_MAX_USD=

# Anthropic
ANTHROPIC_API_KEY=

# Models (verify current strings against https://docs.claude.com before changing)
AGENT_MODEL=claude-sonnet-4-6
JUDGE_MODEL=

# Platform connection (MCP and REST are separate URLs; platform runs MCP as its own process — see platform ADR-0006)
PLATFORM_MCP_URL=
PLATFORM_REST_URL=
PLATFORM_TOKEN=
PLATFORM_WEBHOOK_SECRET=

# Agent-owned Postgres
DATABASE_URL=

# Per-incident hard budgets
BUDGET_MAX_TOOL_CALLS=25
BUDGET_MAX_TOKENS=
BUDGET_MAX_SECONDS=
BUDGET_MAX_USD=
